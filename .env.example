# ── LiveKit Cloud（從 https://cloud.livekit.io 取得）─────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin SDK（後端用）────────────────────────────────────────────────
# 步驟：Firebase Console → Project Settings → Service Accounts → Generate new private key
# 方法 A：將下載的 JSON 壓縮為單行字串（推薦用於 Docker / CI）
FIREBASE_SERVICE_ACCOUNT_JSON={}
# 方法 B：本機開發時直接指向 JSON 檔案路徑（擇一即可）
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── PostgreSQL（self-hosted Docker）──────────────────────────────────────────
POSTGRES_USER=tutor
POSTGRES_PASSWORD=tutor
POSTGRES_DB=tutordb
DATABASE_URL=postgresql+psycopg2://tutor:tutor@postgres:5432/tutordb

# ── Internal Agent Secret ──────────────────────────────────────────────────────
INTERNAL_SECRET=internal-agent-secret-change-me

# ── Ollama 外部伺服器（192.168.15.235）────────────────────────────────────────
# 可用模型：qwen3.5:35b / gemma4:31b / gpt-oss:20b
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.2:3b
GOOGLE_API_KEY=AI*******************

# ── Agent 模式切換 ─────────────────────────────────────────────────────────────
# AGENT_MODE=gemini    ← 預設，使用 Google Gemini Realtime（需 GOOGLE_API_KEY）
# AGENT_MODE=local     ← 完全本地，使用 Whisper STT + Ollama LLM + Kokoro/EdgeTTS
AGENT_MODE=gemini

# ── Local 模式：TTS 引擎選擇 ───────────────────────────────────────────────────
# TTS_ENGINE=kokoro     ← 預設，完全離線（需下載 Kokoro ONNX 模型，見 docs/architecture.md）
# TTS_ENGINE=edge-tts   ← Microsoft Edge TTS（需要網路，品質較好）
TTS_ENGINE=kokoro

# ── Local 模式：Kokoro TTS 模型路徑（相對於 livekit-agent/ 執行目錄）──────────
# KOKORO_MODEL_PATH=models/kokoro-v1.0.onnx
# KOKORO_VOICES_PATH=models/voices-v1.0.bin
# KOKORO_VOICE=af_heart

# ── Local 模式：Edge-TTS 語音（TTS_ENGINE=edge-tts 時有效）──────────────────
# EDGE_TTS_VOICE=en-US-JennyNeural

# ── 前端（Cloudflare Pages 環境變數，在 CF Pages 設定頁填入）─────────────────
# VITE_FIREBASE_API_KEY=AIzaSy...
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
# VITE_API_BASE_URL=https://your-backend-domain.com
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Cloudflare R2 (PDF storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=live-english-tutor-materials
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ── Self-hosted LiveKit（搭配 docker-compose.livekit.yml 使用）───────────────
# 啟用方式：make up && make livekit-up
#
# Selfhost 模式需將上方 LiveKit 區段的值改為：
#
#   LIVEKIT_URL=ws://livekit:7880           ← Agent 連線（Docker 內部 hostname）
#   LIVEKIT_PUBLIC_URL=ws://localhost:7880   ← 瀏覽器連線（backend 回傳此 URL）
#   LIVEKIT_API_KEY=devkey                   ← 任意非空字串（需與 server 一致）
#   LIVEKIT_API_SECRET=devsecret            ← 任意非空字串（建議 >=32 chars）
#
# Cloud 模式（預設）：LIVEKIT_PUBLIC_URL 留空，自動 fallback 到 LIVEKIT_URL
# LIVEKIT_PUBLIC_URL=
